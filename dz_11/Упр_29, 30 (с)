def max_profit_billboards(M, x, r):
    n = len(x)

    # Сортируем точки по координатам
    points = sorted(zip(x, r))
    x_sorted = [p[0] for p in points]
    r_sorted = [p[1] for p in points]
    
    # Находим оптимальные совместимые точки
    p = [0] * (n + 1) 
    j = 0  
    for i in range(n):
        while j < i and x_sorted[i] - x_sorted[j] <= 5:
            j += 1
        p[i + 1] = j  
    
    # Находим макс прибыль
    dp = [0] * (n + 1) 
    for i in range(1, n + 1):
        skip = dp[i - 1]
        take = r_sorted[i - 1] + dp[p[i]]
        dp[i] = max(skip, take)
    
    # Восстанавдиваем множества
    selected = []
    i = n
    while i > 0:
        if dp[i] == dp[i - 1]:
            i -= 1
        else:
            selected.append(i - 1) 
            i = p[i]
    
    selected.reverse()
    original_indices = [points[idx] for idx in selected]
    return dp[n], original_indices


M = 20
x = [6, 7, 12, 14]
r = [5, 6, 5, 1]

max_profit, selected = max_profit_billboards(M, x, r)
print(f"Максимальная прибыль: {max_profit}")
print(f"Выбранные точки: {selected}")


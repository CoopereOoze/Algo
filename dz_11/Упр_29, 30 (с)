def max_weight_independent_set(weights):
    n = len(weights)
    if n == 0:
        return 0, []

    dp = [0] * n
    dp[0] = weights[0]
    if n > 1:
        dp[1] = max(weights[0], weights[1])

    for i in range(2, n):
        dp[i] = max(dp[i - 1], dp[i - 2] + weights[i])

    # Восстановление множества
    independent_set = []
    i = n - 1
    while i >= 0:
        if i == 0:
            independent_set.append(i)
            break
        if dp[i] == dp[i - 1]:
            i -= 1
        else:
            independent_set.append(i)
            i -= 2

    independent_set.reverse()
    total_weight = dp[-1]
    return total_weight, independent_set


weights = [1, 8, 6, 3, 6]
total, nodes = max_weight_independent_set(weights)
print("Максимальный общий вес:", total)
print("Индексы узлов в независимом множестве:", nodes)
print("Веса выбранных узлов:", [weights[i] for i in nodes])

def find_peak(arr):
    left, right = 0, len(arr) - 1
    
    while left < right:
        mid = (left + right) // 2
        
        if arr[mid] < arr[mid + 1]:
            left = mid + 1
        else:
            right = mid
    
    return arr[left]

arr = [1, 3, 5, 7, 9, 6, 4, 2]
peak = find_peak(arr)
print(peak)  
